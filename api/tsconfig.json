{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2020",
    "noEmit": false,
    "outDir": "../.vercel/output/functions/api",
    "allowImportingTsExtensions": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["**/*", "../server/**/*", "../drizzle/**/*", "../shared/**/*"]
}
